<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BROLET - Infinite Marketplace</title>
    <!-- Fixed Lucide Icons bundle path -->
    <script src="https://unpkg.com"></script>
    <style>
        /* Base Reset & Background Grid */
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #25a0e2; /* Signature Blooket Sky Blue Grid */
            background-image: radial-gradient(rgba(255, 255, 255, 0.15) 20%, transparent 20%),
                              radial-gradient(rgba(255, 255, 255, 0.15) 20%, transparent 20%);
            background-size: 40px 40px;
            background-position: 0 0, 20px 20px;
            color: white;
            margin: 0;
            padding: 0;
            -webkit-user-select: none;
            user-select: none;
            overflow: hidden;
            height: 100vh;
            display: flex;
        }

        /* Fixed Split Layout Welcome Screen */
        .full-screen {
            position: fixed;
            top: 0; 
            left: 0; 
            width: 100vw; 
            height: 100vh;
            background: #f19d38; /* Signature Blooket Orange */
            display: flex;
            z-index: 1000;
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
        }

        .full-screen.hidden {
            transform: translateY(-100%);
            opacity: 0;
            pointer-events: none;
        }
        
        /* Left Purple Section with Fixed Diagonal Cut-path */
        .home-left {
            background: #7d2ae8; /* Vibrant Blooket Purple */
            width: 55%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            padding-left: 80px;
            text-align: left;
            box-sizing: border-box;
            position: relative;
            z-index: 2;
            clip-path: polygon(0 0, 100% 0, 85% 100%, 0 100%);
        }

        .home-right {
            width: 45%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding-right: 40px;
            box-sizing: border-box;
        }

        /* Typography & UI Styling */
        h1 {
            font-size: 4rem;
            margin: 0 0 10px 0;
            font-weight: 900;
            letter-spacing: 1px;
            text-shadow: 0 4px 0 rgba(0,0,0,0.2);
        }

        p {
            font-size: 1.5rem;
            margin: 0 0 30px 0;
            opacity: 0.9;
        }

        /* Blooket Style Blocky Buttons */
        .blooket-btn {
            background: white;
            color: #7d2ae8;
            border: none;
            padding: 15px 40px;
            font-size: 1.5rem;
            font-weight: bold;
            border-radius: 12px;
            cursor: pointer;
            box-shadow: 0 6px 0 #cccccc;
            transition: transform 0.1s, box-shadow 0.1s;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .blooket-btn:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 #cccccc;
        }

        .blooket-btn-orange {
            color: white;
            background: #f19d38;
            box-shadow: 0 6px 0 #b87014;
        }
        .blooket-btn-orange:active {
            box-shadow: 0 2px 0 #b87014;
        }

        /* Simple App Content Container (Visible after entering) */
        .app-content {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
    </style>
</head>
<body>

    <!-- Main Dynamic Welcome Screen -->
    <div class="full-screen" id="welcomeScreen">
        <div class="home-left">
            <h1>BROLET</h1>
            <p>The Infinite Marketplace.</p>
            <button class="blooket-btn" onclick="enterMarketplace()">
                Enter Market <i data-lucide="arrow-right"></i>
            </button>
        </div>
        <div class="home-right">
            <!-- Simulated secondary option / login side -->
            <button class="blooket-btn blooket-btn-orange">
                <i data-lucide="user"></i> Developer Mode
            </button>
        </div>
    </div>

    <!-- Main Application UI State -->
    <div class="app-content">
        <h1>Marketplace Loaded</h1>
        <p>Your Blooket-inspired backend grid is active and running.</p>
        <button class="blooket-btn blooket-btn-orange" onclick="resetWelcome()">
            <i data-lucide="rotate-ccw"></i> Back to Start
        </button>
    </div>

    <script>
        // Initialize Lucide icon library assets
        lucide.createIcons();

        // Animation handlers for interface state changes
        function enterMarketplace() {
            document.getElementById('welcomeScreen').classList.add('hidden');
        }

        function resetWelcome() {
            document.getElementById('welcomeScreen').classList.remove('hidden');
        }
    </script>
</body>
</html>
